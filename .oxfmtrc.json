{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "sortImports": true,
  "sortTailwindcss": true,
  "ignorePatterns": ["dist", "build", ".electrobun", "node_modules", "coverage"]
}
