{
  "name": "@agentika/daedux",
  "version": "0.1.0",
  "description": "Claude Code analytics dashboard",
  "keywords": [
    "anthropic",
    "claude",
    "cli",
    "dashboard",
    "token",
    "usage"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentika-labs/daedux.git"
  },
  "bin": {
    "daedux": "bin/cli.ts"
  },
  "files": [
    "bin/",
    "src/bun/",
    "src/cli/",
    "src/shared/",
    "dist/",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "prepack": "bun run build:frontend",
    "dev": "concurrently -n cli,vite -c blue,green \"bun bin/cli.ts\" \"vite\"",
    "dev:desktop": "bun run build:native-effects && concurrently -k -n vite,app -c green,yellow \"vite\" \"bunx wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electrobun dev --console\"",
    "build:native-effects": "bash scripts/build-macos-effects.sh",
    "build:frontend": "vite build",
    "build": "bun run build:native-effects && vite build && electrobun build",
    "build:prod": "bun run build:native-effects && vite build && electrobun build --env=stable",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "clean": "rm -rf dist build .electrobun",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.2",
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94",
    "@effect/platform-bun": "^0.87",
    "@fontsource-variable/figtree": "^5.2",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@fontsource/cascadia-code": "^5.2.3",
    "@hugeicons/core-free-icons": "^3.1",
    "@hugeicons/react": "^1.1",
    "@tanstack/query-sync-storage-persister": "^5.95.2",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "drizzle-orm": "^1.0.0-beta.15",
    "effect": "^3.19",
    "electrobun": "latest",
    "react": "^19",
    "react-dom": "^19",
    "react-error-boundary": "^6.1.1",
    "recharts": "2.15.4",
    "tailwind-merge": "^3.5",
    "tw-animate-css": "^1.4"
  },
  "devDependencies": {
    "@effect/language-service": "^0.64",
    "@tailwindcss/vite": "^4.1",
    "@tanstack/react-query-devtools": "5.95.2",
    "@tanstack/router-devtools": "^1.163.3",
    "@tanstack/router-plugin": "^1.163.3",
    "@types/bun": "^1.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1",
    "concurrently": "^9.1",
    "drizzle-kit": "^0.30",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1",
    "typescript": "^5",
    "ultracite": "7.2.3",
    "vite": "^7"
  }
}
