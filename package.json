{
  "name": "claude-usage-monitor",
  "version": "0.1.0",
  "description": "Claude Code token usage dashboard - Desktop app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "bun run build:frontend && electrobun dev --console",
    "dev:hmr": "concurrently \"vite --port 5173\" \"sleep 2 && VITE_DEV_SERVER_URL=http://localhost:5173 electrobun dev --console\"",
    "build:frontend": "vite build",
    "build": "vite build && electrobun build",
    "build:prod": "vite build && electrobun build --env=stable",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:bun": "tsc -p tsconfig.bun.json --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "clean": "rm -rf dist build .electrobun"
  },
  "dependencies": {
    "@base-ui/react": "^1.2",
    "@effect/platform": "^0.94",
    "@effect/platform-bun": "^0.87",
    "@fontsource-variable/figtree": "^5.2",
    "@hugeicons/core-free-icons": "^3.1",
    "@hugeicons/react": "^1.1",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "drizzle-orm": "^1.0.0-beta.15",
    "effect": "^3.19",
    "electrobun": "latest",
    "react": "^19",
    "react-dom": "^19",
    "recharts": "2.15.4",
    "tailwind-merge": "^3.5",
    "tw-animate-css": "^1.4"
  },
  "devDependencies": {
    "@types/bun": "^1.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/node": "^22",
    "@effect/language-service": "^0.64",
    "@vitejs/plugin-react": "^5.1",
    "@tailwindcss/vite": "^4.1",
    "concurrently": "^9.1",
    "shadcn": "^3.8",
    "tailwindcss": "^4.1",
    "typescript": "^5",
    "vite": "^7",
    "drizzle-kit": "^0.30"
  }
}
